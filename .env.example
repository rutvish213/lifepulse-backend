# ===== LIFE PULSE — ENVIRONMENT VARIABLES =====
# Copy this file to .env and fill in your values

# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/lifepulse
# For MongoDB Atlas (production):
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/lifepulse

# JWT Secrets (use strong random strings in production)
JWT_SECRET=lifepulse_jwt_secret_change_this_in_production_2025
JWT_REFRESH_SECRET=lifepulse_refresh_secret_change_this_in_production_2025
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# OTP (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE=+1XXXXXXXXXX

# Email (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key
FROM_EMAIL=noreply@lifepulse.in
FROM_NAME=Life Pulse

# Admin
ADMIN_EMAIL=admin@lifepulse.in
ADMIN_PASSWORD=Admin@LifePulse2025

# File Upload (Cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_key
